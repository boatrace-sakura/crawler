{
    "name": "boatrace-sakura/crawler",
    "description": "The Boatrace Sakura Crawler.",
    "license": "MIT",
    "type": "library",
    "authors": [
        {
            "name": "shimomo",
            "email": "developer@shimomo.net"
        }
    ],
    "require": {
        "php": "^8.1",
        "boatrace-sakura/converter": "^1.0",
        "illuminate/support": "^9.0 || ^10.0 || ^11.0",
        "nesbot/carbon": "^2.0 || ^3.0",
        "php-di/php-di": "^6.0 || ^7.0",
        "symfony/browser-kit": "^6.0 || ^7.0",
        "symfony/css-selector": "^6.0 || ^7.0",
        "symfony/http-client": "^6.0 || ^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.0"
    },
    "autoload": {
        "psr-4": {
            "Boatrace\\Sakura\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Boatrace\\Sakura\\Tests\\": "tests/"
        }
